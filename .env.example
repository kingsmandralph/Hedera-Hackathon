# settle402 — Hedera testnet config. Copy to .env (gitignored) and fill in.
# ECDSA accounts ONLY — 0x-prefixed hex private keys. Create at https://portal.hedera.com
# Testnet keys have ZERO real value, but never commit real values.

NETWORK=hedera:testnet
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# Facilitator = fee-payer: co-signs + submits every transfer, pays network fees. Fund >= 50 HBAR.
FACILITATOR_ACCOUNT_ID=0.0.xxxxxxx
FACILITATOR_PRIVATE_KEY=0x...
FACILITATOR_PORT=4020
FACILITATOR_URL=http://localhost:4020

# Server = payTo: receives payment, hosts the file catalog + settle gate. Fund >= 10 HBAR.
SERVER_ACCOUNT_ID=0.0.xxxxxxx
SERVER_PRIVATE_KEY=0x...
SERVER_PORT=4021

# Buyer = the paying agent: builds + partially signs the TransferTransaction. Fund >= 10 HBAR.
BUYER_ACCOUNT_ID=0.0.xxxxxxx
BUYER_PRIVATE_KEY=0x...

# Demo toggles (default hardened / honest)
NAIVE_MODE=false
FAULTY_MODE=false
